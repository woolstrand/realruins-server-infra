# ============================================================
# woolstrand.art infrastructure — Environment Configuration
#
# Copy this file to .env and fill in every value marked TODO.
# NEVER commit the real .env to version control.
#
# See also:
#   .env.prod.example    — production-only variable reference
#   .env.staging.example — staging-only variable reference
# ============================================================

# ── Shared Infrastructure ─────────────────────────────────────────────────────

# MySQL root password — generate with: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=TODO_strong_root_password

# ── Production: Vapor API ─────────────────────────────────────────────────────

# Docker image for the production Vapor app.
# Build and push this image from the application repository.
# Use a specific digest or tag for reproducible deployments.
PROD_VAPOR_IMAGE=ghcr.io/woolstrand/realruins-api:latest

# Production Vapor database credentials
PROD_DB_NAME=realruins_prod
PROD_DB_USER=realruins_prod
PROD_DB_PASSWORD=TODO_prod_db_password
PROD_MYSQL_PASSWORD=TODO_prod_mysql_password

# Production Vapor S3 credentials (for media/asset storage)
PROD_S3_API_KEY=TODO_prod_s3_api_key
PROD_S3_API_SECRET=TODO_prod_s3_api_secret

# ── Production: WordPress ─────────────────────────────────────────────────────

PROD_WP_DB_NAME=wordpress_prod
PROD_WP_DB_USER=wordpress_prod
PROD_WP_DB_PASSWORD=TODO_prod_wp_password

# ── Staging: Vapor API ────────────────────────────────────────────────────────

# Docker image for the staging Vapor app.
STAGING_VAPOR_IMAGE=ghcr.io/woolstrand/realruins-api:staging

# Staging Vapor database credentials
STAGING_DB_NAME=realruins_staging
STAGING_DB_USER=realruins_staging
STAGING_DB_PASSWORD=TODO_staging_db_password
STAGING_MYSQL_PASSWORD=TODO_staging_mysql_password

# Staging Vapor S3 credentials (for media/asset storage)
STAGING_S3_API_KEY=TODO_staging_s3_api_key
STAGING_S3_API_SECRET=TODO_staging_s3_api_secret
