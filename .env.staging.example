# Staging environment variables — reference
# These variables live in your main .env file (see .env.example).
# This file documents which variables are staging-specific.

STAGING_VAPOR_IMAGE=ghcr.io/woolstrand/realruins-server:latest

STAGING_DB_NAME=realruins_staging
STAGING_DB_USER=realruins_staging
STAGING_DB_PASSWORD=TODO_staging_db_password
STAGING_MYSQL_PASSWORD=TODO_staging_mysql_password

STAGING_S3_API_KEY=TODO_staging_s3_api_key
STAGING_S3_API_SECRET=TODO_staging_s3_api_secret
STAGING_S3_BUCKET=realruins-staging
STAGING_S3_REGION=SFO3
